	description="Legal notice for Glyph."
	summary="This page contains the basic operator and contact details for Glyph."
>
	<section class="legal-section">
		<h2>Operator</h2>
		<p>Glyph is created and maintained by the developer.</p>
	</section>

	<section class="legal-section">
		<h2>Contact</h2>
		<ul>
			<li>Email: <a href="mailto:karatsidhu@gmail.com">karatsidhu@gmail.com</a></li>
			<li>Project page: <a href="https://github.com/SidhuK/Glyph" target="_blank" rel="noopener">github.com/SidhuK/Glyph</a></li>
		</ul>
	</section>

	<section class="legal-section">
		<h2>Product Status</h2>
		<ul>
			<li>Glyph is commercial software</li>
			<li>Official release binaries may be licensed even when parts of the project are public source code</li>
		</ul>
	</section>

	<section class="legal-section">
		<h2>Third-Party Services</h2>
		<ul>
			<li>Payments may be handled by Gumroad</li>
			<li>Releases and source code may be hosted on GitHub</li>
			<li>Optional AI features may involve third-party model providers chosen by the user</li>
		</ul>
