---
import darkShowcaseAsset from "../../assets/dark.webp";
import lightShowcaseAsset from "../../assets/light.webp";
import logoG from "../../assets/logo_g.PNG";
import Layout from "../layouts/Layout.astro";

const showcaseSizes = "(max-width: 1200px) 96vw, 1100px";
const showcaseWidth = lightShowcaseAsset.width;
const showcaseHeight = lightShowcaseAsset.height;

const features = [
	{
		num: "01",
		cat: "EDITOR",
		title: "Markdown-native.",
		desc: "A distraction-free editor with a floating toolbar, slash commands, and live preview. Every note is a plain .md file you own forever.",
	},
	{
		num: "02",
		cat: "CONNECTIONS",
		title: "Wikilinks & backlinks.",
		desc: "Connect any idea to any other with [[wikilinks]]. See what links back. Your notes stay linked together — no folders, no silos.",
	},
	{
		num: "03",
		cat: "INTELLIGENCE",
		title: "AI that knows you.",
		desc: "Ask questions about your own notes. Summarize, compare, or draft — powered by your existing ChatGPT subscription (Plus, Team, or Pro), Anthropic, or a local model you control.",
	},
	{
		num: "04",
		cat: "PRODUCTIVITY",
		title: "Tasks, tables & boards.",
		desc: "Drop a checkbox in any note. Organize with tables and kanban boards. Glyph pulls tasks into Inbox, Today, and Upcoming — no separate app needed.",
	},
	{
		num: "05",
		cat: "SEARCH",
		title: "Find anything, instantly.",
		desc: "Hit ⌘P and find anything — by tag, folder, or full-text. Results appear before you finish typing.",
	},
	{
		num: "06",
		cat: "CUSTOMIZATION",
		title: "Make it yours.",
		desc: "Accent colors, custom fonts, daily notes, and shortcuts — bend Glyph to match how you think.",
	},
];

const faqs = [
	{
		q: "Is there a subscription?",
		a: "No. Glyph is a one-time purchase with lifetime access. No recurring fees, no seat limits, no device binding.",
	},
	{
		q: "Do you collect my data?",
		a: "Never. Your notes stay on your Mac as plain markdown files. Nothing is uploaded, tracked, or phoned home. Ever.",
	},
	{
		q: "Can I try it before buying?",
		a: 'Yes. Glyph comes with a 48-hour free trial. No credit card required — just <a href="https://github.com/SidhuK/Glyph/releases" target="_blank" rel="noopener" style="text-decoration:underline">download the latest version</a> and start writing.',
	},
	{
		q: "I can't afford it at the listed price. What should I do?",
		a: 'Please reach out on <a href="https://x.com/karat_sidhu" target="_blank" rel="noopener" style="text-decoration:underline">X</a> or email <a href="mailto:karatsidhu@gmail.com" style="text-decoration:underline">karatsidhu@gmail.com</a>. If you are a student or really strapped for cash, I will happily send you a discount code or a free license key.',
	},
	{
		q: "Is it open source?",
		a: "Yes. The source code is public on GitHub. Official release binaries are licensed, but you can always build from source.",
	},
	{
		q: "Is a Windows version planned?",
		a: "Eventually, yes. Glyph is built with cross-platform technology, so Windows and Linux are absolutely possible. Right now, all my energy goes into making the Mac experience exceptional.",
	},
];
---

<Layout
	preloadImage={lightShowcaseAsset.src}
	preloadImageSizes={showcaseSizes}
>
	<div class="page">

		<!-- ── HEADER ── -->
		<header class="header">
			<a href="/" class="logo">
				<img src={logoG.src} alt="" class="logo-icon" />
				<span>GLYPH</span>
				<span class="logo-version">EARLY ACCESS</span>
			</a>
			<nav class="nav">
				<a href="/docs">Docs</a>
				<a href="https://github.com/SidhuK/Glyph" target="_blank" rel="noopener">GitHub</a>
				<a href="https://github.com/SidhuK/Glyph/releases" target="_blank" rel="noopener">Changelog</a>
			</nav>
			<a href="https://karatsidhu.gumroad.com/l/sqxfay" class="header-cta" target="_blank" rel="noopener">Get Glyph ↗</a>
		</header>

		<!-- ── HERO ── -->
		<section class="hero">
			<p class="label">LOCAL-FIRST · MARKDOWN · MACOS</p>
			<h1>A quiet place for your<br />thoughts and ideas</h1>
			<p class="hero-sub">Write in markdown. Connect ideas with links. Let AI help when you ask. Everything lives on your machine — plain files, always yours.</p>
			<div class="hero-cta-stack">
				<div class="hero-actions">
					<a href="https://karatsidhu.gumroad.com/l/sqxfay" class="btn-primary" target="_blank" rel="noopener">Get Started</a>
					<a href="https://github.com/SidhuK/Glyph" class="btn-github" target="_blank" rel="noopener">
						<svg class="btn-github-mark" viewBox="0 0 438.549 438.549" aria-hidden="true">
							<path d="M409.132 114.573c-19.608-33.596-46.205-60.194-79.798-79.8-33.598-19.607-70.277-29.408-110.063-29.408-39.781 0-76.472 9.804-110.063 29.408-33.596 19.605-60.192 46.204-79.8 79.8C9.803 148.168 0 184.854 0 224.63c0 47.78 13.94 90.745 41.827 128.906 27.884 38.164 63.906 64.572 108.063 79.227 5.14.954 8.945.283 11.419-1.996 2.475-2.282 3.711-5.14 3.711-8.562 0-.571-.049-5.708-.144-15.417a2549.81 2549.81 0 01-.144-25.406l-6.567 1.136c-4.187.767-9.469 1.092-15.846 1-6.374-.089-12.991-.757-19.842-1.999-6.854-1.231-13.229-4.086-19.13-8.559-5.898-4.473-10.085-10.328-12.56-17.556l-2.855-6.57c-1.903-4.374-4.899-9.233-8.992-14.559-4.093-5.331-8.232-8.945-12.419-10.848l-1.999-1.431c-1.332-.951-2.568-2.098-3.711-3.429-1.142-1.331-1.997-2.663-2.568-3.997-.572-1.335-.098-2.43 1.427-3.289 1.525-.859 4.281-1.276 8.28-1.276l5.708.853c3.807.763 8.516 3.042 14.133 6.851 5.614 3.806 10.229 8.754 13.846 14.842 4.38 7.806 9.657 13.754 15.846 17.847 6.184 4.093 12.419 6.136 18.699 6.136 6.28 0 11.704-.476 16.274-1.423 4.565-.952 8.848-2.383 12.847-4.285 1.713-12.758 6.377-22.559 13.988-29.41-10.848-1.14-20.601-2.857-29.264-5.14-8.658-2.286-17.605-5.996-26.835-11.14-9.235-5.137-16.896-11.516-22.985-19.126-6.09-7.614-11.088-17.61-14.987-29.979-3.901-12.374-5.852-26.648-5.852-42.826 0-23.035 7.52-42.637 22.557-58.817-7.044-17.318-6.379-36.732 1.997-58.24 5.52-1.715 13.706-.428 24.554 3.853 10.85 4.283 18.794 7.952 23.84 10.994 5.046 3.041 9.089 5.618 12.135 7.708 17.705-4.947 35.976-7.421 54.818-7.421s37.117 2.474 54.823 7.421l10.849-6.849c7.419-4.57 16.18-8.758 26.262-12.565 10.088-3.805 17.802-4.853 23.134-3.138 8.562 21.509 9.325 40.922 2.279 58.24 15.036 16.18 22.559 35.787 22.559 58.817 0 16.178-1.958 30.497-5.853 42.966-3.9 12.471-8.941 22.457-15.125 29.979-6.191 7.521-13.901 13.85-23.131 18.986-9.232 5.14-18.182 8.85-26.84 11.136-8.662 2.286-18.415 4.004-29.263 5.146 9.894 8.562 14.842 22.077 14.842 40.539v60.237c0 3.422 1.19 6.279 3.572 8.562 2.379 2.279 6.136 2.95 11.276 1.995 44.163-14.653 80.185-41.062 108.068-79.226 27.88-38.161 41.825-81.126 41.825-128.906-.01-39.771-9.818-76.454-29.414-110.049z"></path>
						</svg>
						<span>Star on GitHub</span>
						<span class="btn-github-stars" aria-hidden="true">
							<svg class="btn-github-star" viewBox="0 0 24 24">
								<path d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z"></path>
							</svg>
						</span>
					</a>
				</div>
				<div class="install-strip" aria-label="Homebrew install command" data-install-strip>
					<div class="install-strip-bar">
						<code class="install-strip-code" data-install-command>brew install --cask SidhuK/glyph/glyph</code>
						<button class="install-strip-copy" type="button" data-copy-install aria-label="Copy Homebrew install command" title="Copy command">
							<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<rect x="9" y="9" width="10" height="10" rx="2"></rect>
								<path d="M5 15V7a2 2 0 0 1 2-2h8"></path>
							</svg>
						</button>
					</div>
					<p class="install-strip-status" data-install-status aria-live="polite">Ready for Terminal.</p>
				</div>
			</div>
		</section>

		<!-- ── SHOWCASE ── -->
		<section class="showcase">
				<div class="showcase-wrap">
					<img
						class="showcase-img"
						src={lightShowcaseAsset.src}
						sizes={showcaseSizes}
						width={showcaseWidth}
						height={showcaseHeight}
						alt="Glyph in light mode"
						loading="eager"
						decoding="async"
						fetchpriority="high"
						data-light-src={lightShowcaseAsset.src}
						data-dark-src={darkShowcaseAsset.src}
						data-light-alt="Glyph in light mode"
						data-dark-alt="Glyph in dark mode"
					/>
			</div>
			<div class="mode-toggle-wrap">
				<button
					class="mode-toggle"
					type="button"
					data-mode-toggle
					aria-label="Switch between light and dark preview"
					aria-pressed="false"
				>
					<svg class="mode-icon icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
					<svg class="mode-icon icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
				</button>
			</div>
		</section>

		<!-- ── FEATURES ── -->
		<section class="section" data-reveal>
			<p class="label">FEATURES</p>
			<h2>Not your average<br />notes app</h2>
			<div class="features-grid">
				{features.map((f) => (
					<div class="feature-cell">
						<p class="feature-label"><span class="feature-num">{f.num}</span> {f.cat}</p>
						<h3 class="feature-title">{f.title}</h3>
						<p class="feature-desc">{f.desc}</p>
					</div>
				))}
			</div>
		</section>

		<!-- ── LOCAL-FIRST ── -->
		<section class="section" data-reveal>
			<p class="label">PRIVACY</p>
			<h2>Yours, completely</h2>
			<p class="section-sub">Your notes never leave your machine. No account, no cloud, no telemetry. Open a folder and start writing.</p>
			<div class="privacy-grid">
				<div class="privacy-cell privacy-cell--tip">
					<p class="privacy-stat">0</p>
					<p class="privacy-label">data collected</p>
					<div class="tip-card">
						<p class="tip-title">Private by default</p>
						<ul class="tip-list">
							<li>No account required to use Glyph</li>
							<li>No telemetry, tracking, or sync layer</li>
							<li>Your notes stay available even without internet</li>
						</ul>
						<p class="tip-foot">Glyph works locally first, so privacy and offline access are built in from the start.</p>
					</div>
				</div>
				<div class="privacy-cell privacy-cell--tip">
					<p class="privacy-stat">.md</p>
					<p class="privacy-label">plain files you own</p>
					<div class="tip-card">
						<p class="tip-title">No lock-in</p>
						<ul class="tip-list">
							<li>Every note is saved as a standard markdown file</li>
							<li>Open your folder anytime in Finder or another editor</li>
							<li>Your notes stay yours, even if you stop using Glyph</li>
						</ul>
						<p class="tip-foot">Glyph organizes your notes without trapping them in a proprietary format.</p>
					</div>
				</div>
				<div class="privacy-cell privacy-cell--tip">
					<p class="privacy-stat">&lt;40<span class="privacy-unit">MB</span></p>
					<p class="privacy-label">app size</p>
					<div class="tip-card">
						<p class="tip-title">Why so small?</p>
						<ul class="tip-list">
							<li>Built natively with Tauri &amp; Rust</li>
							<li>No Electron, no bundled browser</li>
							<li>Uses under 250 MB of memory</li>
						</ul>
						<p class="tip-foot">A lean, fast app that respects your disk and your battery.</p>
					</div>
				</div>
				<div class="privacy-cell privacy-cell--tip">
					<p class="privacy-stat">BYOK</p>
					<p class="privacy-label">bring your own AI key</p>
					<div class="tip-card">
						<p class="tip-title">Supported providers</p>
						<ul class="tip-list">
							<li>OpenAI / ChatGPT (Plus, Team, Pro)</li>
							<li>Anthropic (Claude)</li>
							<li>Google Gemini</li>
							<li>OpenRouter</li>
							<li>Local models (Ollama, LM Studio)</li>
						</ul>
						<p class="tip-foot">Use your own API key — I never store or proxy it.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ── DESIGN ── -->
		<section class="section" data-reveal>
			<p class="label">DESIGN</p>
			<h2>Obsessively crafted</h2>
			<p class="section-sub">A native macOS app built by a solo developer who sweats the details. Every pixel, every shortcut, every transition.</p>
		</section>

		<!-- ── FAQ ── -->
		<section class="section" data-reveal>
			<p class="label">FREQUENT CONCERNS</p>
			<h2>Everything you need to<br />know before you begin</h2>
			<div class="faq-list">
				{faqs.map((f) => (
					<details class="faq-item">
						<summary class="faq-summary">
							<span class="faq-q">{f.q}</span>
							<span class="faq-plus">+</span>
						</summary>
						<p class="faq-a" set:html={f.a} />
					</details>
				))}
			</div>
		</section>

		<!-- ── CTA ── -->
		<section class="section cta" data-reveal>
			<p class="label">YOUR NEXT STEP</p>
			<h2>Start writing with<br />Glyph today</h2>
			<div class="cta-actions">
				<a href="https://karatsidhu.gumroad.com/l/sqxfay" class="btn-primary" target="_blank" rel="noopener">Get Glyph</a>
				<a href="https://github.com/SidhuK/Glyph" class="btn-github" target="_blank" rel="noopener">
					<svg class="btn-github-mark" viewBox="0 0 438.549 438.549" aria-hidden="true">
						<path d="M409.132 114.573c-19.608-33.596-46.205-60.194-79.798-79.8-33.598-19.607-70.277-29.408-110.063-29.408-39.781 0-76.472 9.804-110.063 29.408-33.596 19.605-60.192 46.204-79.8 79.8C9.803 148.168 0 184.854 0 224.63c0 47.78 13.94 90.745 41.827 128.906 27.884 38.164 63.906 64.572 108.063 79.227 5.14.954 8.945.283 11.419-1.996 2.475-2.282 3.711-5.14 3.711-8.562 0-.571-.049-5.708-.144-15.417a2549.81 2549.81 0 01-.144-25.406l-6.567 1.136c-4.187.767-9.469 1.092-15.846 1-6.374-.089-12.991-.757-19.842-1.999-6.854-1.231-13.229-4.086-19.13-8.559-5.898-4.473-10.085-10.328-12.56-17.556l-2.855-6.57c-1.903-4.374-4.899-9.233-8.992-14.559-4.093-5.331-8.232-8.945-12.419-10.848l-1.999-1.431c-1.332-.951-2.568-2.098-3.711-3.429-1.142-1.331-1.997-2.663-2.568-3.997-.572-1.335-.098-2.43 1.427-3.289 1.525-.859 4.281-1.276 8.28-1.276l5.708.853c3.807.763 8.516 3.042 14.133 6.851 5.614 3.806 10.229 8.754 13.846 14.842 4.38 7.806 9.657 13.754 15.846 17.847 6.184 4.093 12.419 6.136 18.699 6.136 6.28 0 11.704-.476 16.274-1.423 4.565-.952 8.848-2.383 12.847-4.285 1.713-12.758 6.377-22.559 13.988-29.41-10.848-1.14-20.601-2.857-29.264-5.14-8.658-2.286-17.605-5.996-26.835-11.14-9.235-5.137-16.896-11.516-22.985-19.126-6.09-7.614-11.088-17.61-14.987-29.979-3.901-12.374-5.852-26.648-5.852-42.826 0-23.035 7.52-42.637 22.557-58.817-7.044-17.318-6.379-36.732 1.997-58.24 5.52-1.715 13.706-.428 24.554 3.853 10.85 4.283 18.794 7.952 23.84 10.994 5.046 3.041 9.089 5.618 12.135 7.708 17.705-4.947 35.976-7.421 54.818-7.421s37.117 2.474 54.823 7.421l10.849-6.849c7.419-4.57 16.18-8.758 26.262-12.565 10.088-3.805 17.802-4.853 23.134-3.138 8.562 21.509 9.325 40.922 2.279 58.24 15.036 16.18 22.559 35.787 22.559 58.817 0 16.178-1.958 30.497-5.853 42.966-3.9 12.471-8.941 22.457-15.125 29.979-6.191 7.521-13.901 13.85-23.131 18.986-9.232 5.14-18.182 8.85-26.84 11.136-8.662 2.286-18.415 4.004-29.263 5.146 9.894 8.562 14.842 22.077 14.842 40.539v60.237c0 3.422 1.19 6.279 3.572 8.562 2.379 2.279 6.136 2.95 11.276 1.995 44.163-14.653 80.185-41.062 108.068-79.226 27.88-38.161 41.825-81.126 41.825-128.906-.01-39.771-9.818-76.454-29.414-110.049z"></path>
					</svg>
					<span>Star on GitHub</span>
					<span class="btn-github-stars" aria-hidden="true">
						<svg class="btn-github-star" viewBox="0 0 24 24">
							<path d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z"></path>
						</svg>
					</span>
				</a>
			</div>
		</section>

		<section class="early-access-note" data-reveal>
			<p class="label">EARLY ACCESS</p>
			<h2>Still early. Actively evolving.</h2>
			<p class="section-sub early-access-copy">Glyph is in early access and active development. I am building it as a solo developer project, and your support helps me keep developing it further.</p>
		</section>

		<!-- ── FOOTER ── -->
		<footer class="footer">
			<div class="footer-inner">
				<div class="footer-col">
					<a href="/" class="logo">
						<img src={logoG.src} alt="" class="logo-icon" />
						<span>GLYPH</span>
					</a>
				</div>
				<div class="footer-col">
					<p class="footer-heading">PRODUCT</p>
					<a href="/docs">Docs</a>
					<a href="https://github.com/SidhuK/Glyph/releases" target="_blank" rel="noopener">Changelog</a>
					<a href="https://github.com/SidhuK/Glyph" target="_blank" rel="noopener">GitHub</a>
				</div>
				<div class="footer-col">
					<p class="footer-heading">PURCHASE</p>
					<a href="https://karatsidhu.gumroad.com/l/sqxfay" target="_blank" rel="noopener">Gumroad</a>
				</div>
				<div class="footer-col">
					<p class="footer-heading">LEGAL</p>
					<a href="/terms">Terms</a>
					<a href="/privacy">Privacy</a>
					<a href="/legal">Legal</a>
				</div>
			</div>
			<p class="footer-copy">© 2026 Glyph. All rights reserved.</p>
		</footer>

	</div>
</Layout>

<style>
	/* ── Page ── */
	.page {
		width: min(720px, 90vw);
		margin-inline: auto;
	}

	/* ── Header ── */
	.header {
		position: sticky;
		top: 0;
		z-index: 100;
		display: flex;
		align-items: center;
		padding: 0.75rem 0;
		background: transparent;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.14em;
	}

	.logo-icon {
		width: 1.25rem;
		height: 1.25rem;
		border-radius: 4px;
	}

	.logo-version {
		font-size: 0.55rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		color: var(--faint);
		border: 1px solid var(--border);
		padding: 0.1rem 0.35rem;
		border-radius: 3px;
