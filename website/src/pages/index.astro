<script>
	const defaultCopyLabel = 'Copy command';
	const copiedCopyLabel = 'Copied';
	const failedCopyLabel = 'Copy failed';

	const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (prefersReducedMotion || !('IntersectionObserver' in window)) {
		revealItems.forEach((el) => el.classList.add('revealed'));
	} else {
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.remove('reveal-pending');
						entry.target.classList.add('revealed');
						observer.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.1 }
		);

		revealItems.forEach((el) => {
			const rect = el.getBoundingClientRect();
			if (rect.top <= window.innerHeight * 0.92) {
				el.classList.add('revealed');
				return;
			}

			el.classList.add('reveal-pending');
			observer.observe(el);
		});
	}

	const toggle = document.querySelector('[data-mode-toggle]');
	const showcase = toggle?.closest('.showcase');
	const showcaseImage = showcase?.querySelector('.showcase-img');
	let isDarkMode = false;

	const setShowcaseMode = (darkMode) => {
		if (!(showcaseImage instanceof HTMLImageElement)) return;

		const nextSrc = darkMode ? showcaseImage.dataset.darkSrc : showcaseImage.dataset.lightSrc;
		const nextAlt = darkMode ? showcaseImage.dataset.darkAlt : showcaseImage.dataset.lightAlt;

		if (nextSrc) showcaseImage.src = nextSrc;
		showcaseImage.removeAttribute('srcset');
		if (nextAlt) showcaseImage.alt = nextAlt;

		showcase?.classList.toggle('is-dark', darkMode);
		toggle?.setAttribute('aria-pressed', String(darkMode));
	};

	toggle?.addEventListener('click', () => {
		isDarkMode = !isDarkMode;
		setShowcaseMode(isDarkMode);
	});

	const copyButton = document.querySelector('[data-copy-install]');
	const installStrip = document.querySelector('[data-install-strip]');
	const installStatus = document.querySelector('[data-install-status]');
	const installCommand = document.querySelector('[data-install-command]')?.textContent?.trim();
	let copyResetTimer;

	copyButton?.addEventListener('click', async () => {
		if (!installCommand || !(installStrip instanceof HTMLElement)) return;

		installStrip.classList.remove('is-copied');
		installStrip.classList.remove('is-failed');
		copyButton.classList.remove('is-copied');
		copyButton.classList.remove('is-failed');
		installStrip.classList.add('is-typing');
		if (installStatus instanceof HTMLElement) {
			installStatus.textContent = 'Typing the command into memory...';
		}
		window.clearTimeout(copyResetTimer);

		try {
			await navigator.clipboard.writeText(installCommand);
			window.setTimeout(() => {
				installStrip.classList.remove('is-typing');
				installStrip.classList.add('is-copied');
				copyButton.classList.add('is-copied');
				copyButton.classList.remove('is-failed');
				copyButton.setAttribute('aria-label', copiedCopyLabel);
				copyButton.setAttribute('title', copiedCopyLabel);
				if (installStatus instanceof HTMLElement) {
					installStatus.textContent = 'Copied. Paste into Terminal.';
				}
			}, 180);
			copyResetTimer = window.setTimeout(() => {
				installStrip.classList.remove('is-typing');
				installStrip.classList.remove('is-copied');
				copyButton.classList.remove('is-copied');
				copyButton.setAttribute('aria-label', defaultCopyLabel);
				copyButton.setAttribute('title', defaultCopyLabel);
				if (installStatus instanceof HTMLElement) {
					installStatus.textContent = 'Ready for Terminal.';
				}
			}, 1900);
		} catch {
			installStrip.classList.remove('is-typing');
			installStrip.classList.add('is-failed');
			copyButton.classList.add('is-failed');
			copyButton.setAttribute('aria-label', failedCopyLabel);
			copyButton.setAttribute('title', failedCopyLabel);
			if (installStatus instanceof HTMLElement) {
				installStatus.textContent = 'Clipboard access blocked. You can still copy it manually.';
			}
			copyResetTimer = window.setTimeout(() => {
				installStrip.classList.remove('is-failed');
				copyButton.classList.remove('is-failed');
				copyButton.setAttribute('aria-label', defaultCopyLabel);
				copyButton.setAttribute('title', defaultCopyLabel);
				if (installStatus instanceof HTMLElement) {
					installStatus.textContent = 'Ready for Terminal.';
				}
			}, 2200);
		}
	});
</script>
