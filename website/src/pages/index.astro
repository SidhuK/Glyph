---
import Layout from '../layouts/Layout.astro';

const stats = [
  { value: '< 1s', label: 'to launch' },
  { value: '~80 MB', label: 'of memory' },
  { value: '0 bytes', label: 'uploaded' },
  { value: '.md', label: 'plain files' },
];
---

<Layout>
  <main class="page">
    <!-- ── NAV ── -->
    <header class="topbar shell">
      <a href="#" class="brand" aria-label="Glyph home">
        <img class="brand-mark" src="/glyph-logo.png" alt="" aria-hidden="true" />
        <span class="brand-text">Glyph</span>
      </a>
      <nav class="nav" aria-label="Main navigation">
        <a href="#features">Features</a>
        <a href="#use-cases">Use Cases</a>
      </nav>
      <a class="nav-cta" href="#">
        Download
        <span class="nav-cta-arrow" aria-hidden="true">↓</span>
      </a>
    </header>

    <!-- ── HERO ── -->
    <section class="hero shell">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="badge">
            <span class="badge-dot" aria-hidden="true"></span>
            Now available for macOS
          </p>
          <h1>
            <span class="h1-line">Your notebook,</span>
            <span class="h1-line">but it thinks</span>
            <span class="h1-line">with you.</span>
          </h1>
          <p class="lede">
            Glyph is a desktop app for writing, connecting, and
            exploring your notes — with an AI that actually reads
            what you've written.
          </p>
          <div class="actions">
            <a href="#" class="btn btn-primary">
              Download for macOS
              <span class="btn-arrow" aria-hidden="true">→</span>
            </a>
            <a href="#" class="btn btn-ghost">View on GitHub</a>
          </div>
        </div>
        <div class="hero-media-wrap">
          <div class="hero-glow" aria-hidden="true"></div>
          <div class="hero-float hero-float--cmd" aria-hidden="true">⌘P</div>
          <div class="hero-float hero-float--link" aria-hidden="true">[[Research Notes]]</div>
          <div class="hero-float hero-float--task" aria-hidden="true">
            <span class="hf-check">✓</span>
            Review outline
          </div>
          <img
            class="hero-media"
            src="/main-image.png"
            alt="Glyph workspace showing the markdown editor, file tree, and AI chat panel"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- ── FEATURES BENTO ── -->
    <section id="features" class="features-section shell">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Features</p>
        <h2>Everything you need to think&nbsp;clearly.</h2>
      </div>

      <div class="bento">
        <!-- Write (tall) -->
        <article class="bento-card tall" data-reveal>
          <h3>Write.</h3>
          <p class="bento-sub">A clean editor with a floating toolbar, slash commands, and live preview</p>
          <p>Everything you type is saved as a plain .md file. Open your notes in any app, anytime.</p>
          <div class="mockup m-editor" aria-hidden="true">
            <div class="m-bar">
              <span class="m-dot"></span><span class="m-dot"></span><span class="m-dot"></span>
            </div>
            <div class="m-body">
              <div class="m-ln heading" style="width: 50%"></div>
              <div class="m-ln" style="width: 92%"></div>
              <div class="m-ln" style="width: 70%"></div>
              <div class="m-ln sel" style="width: 85%"></div>
              <div class="m-ln" style="width: 55%"></div>
              <div class="m-ln" style="width: 78%"></div>
              <div class="m-ln" style="width: 40%"></div>
            </div>
          </div>
        </article>

        <!-- Connect (tall) -->
        <article class="bento-card tall" data-reveal style="--delay: 80ms">
          <h3>Connect.</h3>
          <p class="bento-sub">Link notes with [[wikilinks]] and see what links&nbsp;back</p>
          <p>Drag notes, images, and web links onto a spatial canvas. Watch your thinking take shape.</p>
          <svg class="mockup m-canvas-svg" viewBox="0 0 240 170" aria-hidden="true">
            <line x1="60" y1="45" x2="135" y2="95" style="stroke: #DAD6CE; stroke-width: 1.5"/>
            <line x1="135" y1="95" x2="195" y2="50" style="stroke: #DAD6CE; stroke-width: 1.5"/>
            <line x1="60" y1="45" x2="85" y2="140" style="stroke: #DAD6CE; stroke-width: 1.5"/>
            <line x1="85" y1="140" x2="135" y2="95" style="stroke: #DAD6CE; stroke-width: 1.5"/>
            <circle cx="60" cy="45" r="22" style="fill: #F8F7F3; stroke: #DAD6CE; stroke-width: 1.5"/>
            <text x="60" y="48" text-anchor="middle" style="fill: #7A766D; font-size: 9px; font-family: system-ui">Ideas</text>
            <circle cx="135" cy="95" r="26" style="fill: #E8EDE6; stroke: #4A6741; stroke-width: 2"/>
            <text x="135" y="98" text-anchor="middle" style="fill: #4A6741; font-size: 9px; font-weight: 600; font-family: system-ui">Draft</text>
            <circle cx="195" cy="50" r="20" style="fill: #F8F7F3; stroke: #DAD6CE; stroke-width: 1.5"/>
            <text x="195" y="53" text-anchor="middle" style="fill: #7A766D; font-size: 8px; font-family: system-ui">Research</text>
            <circle cx="85" cy="140" r="18" style="fill: #F8F7F3; stroke: #DAD6CE; stroke-width: 1.5"/>
            <text x="85" y="143" text-anchor="middle" style="fill: #7A766D; font-size: 8px; font-family: system-ui">Notes</text>
          </svg>
        </article>

        <!-- Ask -->
        <article class="bento-card" data-reveal style="--delay: 160ms">
          <h3>Ask.</h3>
          <p class="bento-sub">An AI that reads your notes</p>
          <p>Summarize, compare, or draft — with OpenAI, Anthropic, or a local model.</p>
          <div class="mockup m-chat" aria-hidden="true">
            <div class="m-msg m-user">Summarize this week's notes</div>
            <div class="m-msg m-ai">
              <div class="m-ln" style="width: 100%"></div>
              <div class="m-ln" style="width: 88%"></div>
              <div class="m-ln" style="width: 55%"></div>
            </div>
          </div>
        </article>

        <!-- Tasks -->
        <article class="bento-card" data-reveal style="--delay: 200ms">
          <h3>Tasks</h3>
          <p>Write checkboxes in any note. Glyph gathers them into Inbox, Today, and Upcoming.</p>
          <div class="mockup m-tasks" aria-hidden="true">
            <div class="m-task done"><span class="m-check">✓</span><div class="m-ln" style="width: 65%"></div></div>
            <div class="m-task done"><span class="m-check">✓</span><div class="m-ln" style="width: 50%"></div></div>
            <div class="m-task"><span class="m-check"></span><div class="m-ln" style="width: 80%"></div></div>
            <div class="m-task"><span class="m-check"></span><div class="m-ln" style="width: 60%"></div></div>
          </div>
        </article>

        <!-- Search -->
        <article class="bento-card" data-reveal style="--delay: 100ms">
          <h3>Instant search</h3>
          <p>⌘P to find anything. Filter by tags, folders, or full-text content.</p>
          <div class="mockup m-search" aria-hidden="true">
            <div class="m-searchbar">
              <span class="m-search-key">⌘P</span>
              <span class="m-search-text">meeting notes…</span>
            </div>
            <div class="m-result"><div class="m-result-dot"></div><div class="m-ln" style="width: 72%"></div></div>
            <div class="m-result"><div class="m-result-dot"></div><div class="m-ln" style="width: 58%"></div></div>
          </div>
        </article>

        <!-- Daily Notes -->
        <article class="bento-card" data-reveal style="--delay: 150ms">
          <h3>Daily notes</h3>
          <p>A fresh page every morning, auto-titled and ready to go.</p>
          <div class="mockup m-daily" aria-hidden="true">
            <span class="m-daily-day">Sun</span>
            <span class="m-daily-num">02</span>
            <span class="m-daily-month">March 2026</span>
          </div>
        </article>

        <!-- Make it yours -->
        <article class="bento-card" data-reveal style="--delay: 200ms">
          <h3>Make it yours</h3>
          <p>Accent colors, fonts, pinned folders, and keyboard shortcuts — adjust everything.</p>
          <div class="mockup m-customize" aria-hidden="true">
            <div class="m-swatches">
              <span class="m-swatch selected" style="--c: #4A6741"></span>
              <span class="m-swatch" style="--c: #5B7FB5"></span>
              <span class="m-swatch" style="--c: #B8956A"></span>
              <span class="m-swatch" style="--c: #9B6B8E"></span>
              <span class="m-swatch" style="--c: #C75D3A"></span>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- ── PRIVACY ── -->
    <section class="privacy shell">
      <div class="privacy-grid">
        <div class="privacy-content">
          <div class="section-head" data-reveal>
            <p class="eyebrow">Local-first</p>
            <h2>Yours, completely.</h2>
          </div>
          <p class="privacy-text" data-reveal>
            Glyph reads files from your disk and never phones home.
            No account. No subscription. No cloud sync.
            Just open a folder and start writing.
          </p>
        </div>
        <div class="privacy-visual" data-reveal style="--delay: 120ms" aria-hidden="true">
          <div class="m-filetree">
            <div class="m-ft-header">
              <span class="m-ft-dot"></span>
              <span class="m-ft-dot"></span>
              <span class="m-ft-dot"></span>
              <span class="m-ft-title">~/vault</span>
            </div>
            <div class="m-ft-body">
              <div class="m-ft-row folder">Projects</div>
              <div class="m-ft-row file">meeting-notes.md</div>
              <div class="m-ft-row file">architecture.md</div>
              <div class="m-ft-row folder">Daily</div>
              <div class="m-ft-row file">2026-03-02.md</div>
              <div class="m-ft-row file">2026-03-01.md</div>
              <div class="m-ft-row folder">Research</div>
            </div>
          </div>
        </div>
      </div>
      <div class="stats-grid" data-reveal>
        {stats.map((s) => (
          <div class="stat">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ── USE CASES ── -->
    <section id="use-cases" class="use-cases shell">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Who it's for</p>
        <h2>People who think for a&nbsp;living.</h2>
      </div>
      <div class="uc-grid">
        <article class="uc-card" data-reveal>
          <div class="uc-marker" aria-hidden="true">R</div>
          <h3>Researchers</h3>
          <p>Link papers to reading notes, tag concepts across projects, and ask the AI to summarize or compare sources — all from one local vault.</p>
          <div class="uc-visual" aria-hidden="true">
            <span class="uc-wikilink">[[Smith 2024]]</span>
            <span class="uc-arrow">→</span>
            <span class="uc-wikilink">[[Lit Review]]</span>
          </div>
        </article>

        <article class="uc-card" data-reveal style="--delay: 80ms">
          <div class="uc-marker" aria-hidden="true">E</div>
          <h3>Engineers</h3>
          <p>Keep architecture decisions, runbooks, and code snippets in markdown. Use the canvas to map systems and the AI to answer questions about your docs.</p>
          <div class="uc-visual" aria-hidden="true">
            <div class="uc-doc">
              <div class="uc-doc-title">ADR-001: Cache Strategy</div>
              <div class="m-ln" style="width: 85%"></div>
              <div class="m-ln" style="width: 60%"></div>
              <div class="m-ln" style="width: 40%"></div>
            </div>
          </div>
        </article>

        <article class="uc-card" data-reveal style="--delay: 160ms">
          <div class="uc-marker" aria-hidden="true">W</div>
          <h3>Writers</h3>
          <p>Outline chapters on the canvas, write drafts in the editor, and tag scenes by character or theme. The AI helps brainstorm without breaking your flow.</p>
          <div class="uc-visual" aria-hidden="true">
            <div class="uc-outline">
              <div class="uc-chapter">Ch. 1 — The Beginning</div>
              <div class="uc-chapter">Ch. 2 — Rising Action</div>
              <div class="uc-chapter active">Ch. 3 — The Turn</div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="cta-section shell" data-reveal>
      <div class="cta-box">
        <p class="cta-eyebrow">Get started</p>
        <h2>Open a folder.<br />Start&nbsp;writing.</h2>
        <p class="cta-sub">Free to download. Works offline. Your files stay on your machine.</p>
        <div class="actions cta-actions">
          <a href="#" class="btn btn-cta-primary">
            Download for macOS
            <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
          <a href="#" class="btn btn-cta-ghost">View on GitHub</a>
        </div>
      </div>
    </section>

    <!-- ── FOOTER ── -->
    <footer class="footer shell">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="#" class="brand" aria-label="Glyph home">
            <img class="brand-mark" src="/glyph-logo.png" alt="" aria-hidden="true" />
            <span class="brand-text">Glyph</span>
          </a>
          <p class="footer-tagline">A local-first markdown editor with AI.</p>
        </div>
        <div class="footer-links">
          <div class="footer-col">
            <h4>Product</h4>
            <a href="#features">Features</a>
            <a href="#">Changelog</a>
            <a href="#">Pricing</a>
          </div>
          <div class="footer-col">
            <h4>Community</h4>
            <a href="#">Documentation</a>
            <a href="#">GitHub</a>
            <a href="#">Discord</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Glyph. All rights reserved.</p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  /* ── Page ── */
  .page { padding: 1.5rem 0 0; position: relative; }
  .shell { width: min(1200px, 92vw); margin-inline: auto; }
  .section-head { margin-bottom: 3rem; }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    max-width: 560px;
    margin: 0;
    color: var(--ink);
  }

  /* ── Topbar ── */
  .topbar { display: flex; align-items: center; gap: 2rem; padding: 0.75rem 0; }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .brand-mark { width: 1.85rem; height: 1.85rem; object-fit: cover; border-radius: 0.22rem; display: block; }

  .nav { display: flex; align-items: center; gap: 1.8rem; margin-left: auto; }
  .nav a { font-size: 0.88rem; color: var(--muted); font-weight: 500; transition: color 0.2s ease; }
  .nav a:hover { color: var(--ink); }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    padding: 0.45rem 1.1rem;
    border: 1.5px solid var(--accent);
    border-radius: 999px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .nav-cta:hover { background: var(--accent); color: #fff; }
  .nav-cta-arrow { font-size: 0.75rem; }

  /* ── Hero ── */
  .hero { padding: 5rem 0 6rem; }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 4rem;
    align-items: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.38rem 1rem;
    background: var(--accent-soft);
    border-radius: 999px;
    font-size: 0.8rem;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 1.8rem;
  }

  .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5.5vw, 4.2rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    margin: 0 0 1.5rem;
    color: var(--ink);
  }

  .h1-line { display: block; opacity: 0; animation: fadeUp 0.55s ease both; }
  .h1-line:nth-child(1) { animation-delay: 0.1s; }
  .h1-line:nth-child(2) { animation-delay: 0.2s; }
  .h1-line:nth-child(3) { animation-delay: 0.3s; }

  .lede { font-size: 1.12rem; line-height: 1.65; color: var(--muted); max-width: 440px; margin: 0 0 2rem; }
  .actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.72rem 1.5rem;
    border-radius: var(--radius);
    font-size: 0.92rem;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    border: none;
    transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .btn:hover { transform: translateY(-1px); }
  .btn:active { transform: translateY(1px); }
  .btn-arrow { transition: transform 0.2s ease; }
  .btn:hover .btn-arrow { transform: translateX(3px); }

  .btn-primary { background: var(--accent); color: #fff; box-shadow: 0 4px 16px -4px rgba(74, 103, 65, 0.35); }
  .btn-primary:hover { background: #3d5736; box-shadow: 0 8px 24px -4px rgba(74, 103, 65, 0.4); }
  .btn-ghost { background: transparent; border: 1.5px solid var(--line); color: var(--ink); }
  .btn-ghost:hover { border-color: var(--muted); background: var(--surface); }

  /* ── Hero Media ── */
  .hero-media-wrap { position: relative; border-radius: 1rem; overflow: visible; }

  .hero-glow {
    position: absolute;
    inset: -20%;
    background:
      radial-gradient(ellipse at 40% 50%, rgba(74, 103, 65, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 30%, rgba(184, 149, 106, 0.1) 0%, transparent 50%);
    z-index: 0;
    pointer-events: none;
  }

  .hero-media {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.85rem;
    border: 1px solid var(--line);
    box-shadow: 0 24px 80px -16px rgba(21, 19, 14, 0.18), 0 8px 24px -8px rgba(21, 19, 14, 0.08);
    position: relative;
    z-index: 1;
  }

  /* ── Hero Floating Elements ── */
  .hero-float {
    position: absolute;
    z-index: 2;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 0.5rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    box-shadow: 0 8px 24px -8px rgba(21, 19, 14, 0.12);
    white-space: nowrap;
    opacity: 0;
    animation: floatIn 0.6s ease both;
  }

  .hero-float--cmd {
    top: 8%;
    left: -5%;
    font-family: ui-monospace, 'SF Mono', monospace;
    font-weight: 700;
    font-size: 0.7rem;
    color: var(--muted);
    background: var(--bg);
    padding: 0.35rem 0.6rem;
    border-radius: 0.35rem;
    animation-delay: 0.5s;
  }

  .hero-float--link {
    top: 14%;
    right: -4%;
    color: var(--accent);
    background: var(--accent-soft);
    border-color: rgba(74, 103, 65, 0.2);
    animation-delay: 0.65s;
  }

  .hero-float--task {
    bottom: 16%;
    left: -6%;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    animation-delay: 0.8s;
  }

  .hf-check {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    background: var(--accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    flex-shrink: 0;
    line-height: 1;
  }

  /* ── Bento Grid ── */
  .features-section { padding: 5rem 0; }

  .bento { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }

  .bento-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.85rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.25s ease;
  }

  .bento-card:hover { border-color: rgba(74, 103, 65, 0.35); box-shadow: 0 8px 32px -8px rgba(21, 19, 14, 0.07); }
  .bento-card.tall { grid-row: span 2; }

  .bento-card h3 { font-family: var(--font-display); font-size: 1.15rem; font-weight: 700; letter-spacing: -0.015em; margin: 0 0 0.3rem; color: var(--ink); }
  .bento-card.tall h3 { font-size: 1.55rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 0.5rem; }
  .bento-sub { font-size: 0.9rem; color: var(--accent); font-weight: 500; margin: 0 0 0.6rem; line-height: 1.4; }
  .bento-card p { font-size: 0.86rem; line-height: 1.6; color: var(--muted); margin: 0; }
  .bento-card.tall p { font-size: 0.9rem; }

  /* ── Mockups (shared) ── */
  .mockup { margin-top: auto; padding-top: 1.25rem; }
  .m-ln { height: 6px; border-radius: 3px; background: var(--line); }

  .m-editor { background: #fff; border-radius: 0.55rem; border: 1px solid var(--line); overflow: hidden; }
  .m-bar { display: flex; gap: 5px; padding: 7px 10px; border-bottom: 1px solid var(--line); }
  .m-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--line); }
  .m-body { padding: 12px 14px; display: flex; flex-direction: column; gap: 7px; }
  .m-ln.heading { height: 9px; background: var(--ink); opacity: 0.55; border-radius: 4px; }
  .m-ln.sel { background: var(--accent-soft); box-shadow: -4px 0 0 var(--accent-soft), 4px 0 0 var(--accent-soft); }

  .m-canvas-svg { width: 100%; height: auto; margin-top: auto; padding-top: 1rem; }

