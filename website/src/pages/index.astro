---
import Layout from "../layouts/Layout.astro";

const features = [
	{
		num: "01",
		title: "Markdown-native",
		desc: "A distraction-free editor with a floating toolbar, slash commands, and live preview. Every note is a plain .md file you own forever.",
	},
	{
		num: "02",
		title: "Wikilinks & backlinks",
		desc: "Connect any idea to any other with [[wikilinks]]. See what links back. Your notes become a knowledge graph, not a filing cabinet.",
	},
	{
		num: "03",
		title: "AI that actually knows you",
		desc: "Ask questions about your own notes. Summarize, compare, or draft — powered by OpenAI, Anthropic, or a local model you control.",
	},
	{
		num: "04",
		title: "Tasks, everywhere",
		desc: "Drop a checkbox in any note. Glyph pulls them all into Inbox, Today, and Upcoming — no separate app needed.",
	},
];

const details = [
	{
		title: "Instant search",
		desc: "Hit ⌘P and find anything — by tag, folder, or full-text. Results appear before you finish typing.",
	},
	{
		title: "Keyboard-first",
		desc: "Every single action has a shortcut. Navigate, create, and organize without lifting your hands.",
	},
	{
		title: "Make it yours",
		desc: "Accent colors, custom fonts, pinned folders, and shortcuts — bend Glyph to match how you think.",
	},
];

const faqs = [
	{
		q: "Is there a subscription?",
		a: "No. Glyph is free and open source. No subscriptions, no payments, no accounts. Just download and go.",
	},
	{
		q: "Do you collect my data?",
		a: "Never. Your notes stay on your Mac as plain markdown files. Nothing is uploaded, tracked, or phoned home. Ever.",
	},
	{
		q: "Is a Windows version planned?",
		a: "Yes. Glyph is built with Tauri and Rust, so Windows and Linux are on the roadmap.",
	},
];
---

<Layout>
  <main class="page">
    <!-- Decorative squares -->
    <div class="deco deco-1" aria-hidden="true"></div>
    <div class="deco deco-2" aria-hidden="true"></div>
    <div class="deco deco-3" aria-hidden="true"></div>
    <div class="deco deco-4" aria-hidden="true"></div>
    <div class="deco deco-5" aria-hidden="true"></div>

    <!-- ── HEADER ── -->
    <header class="header">
      <a href="#" class="logo" aria-label="Glyph home">
        <img src="/glyph-logo.png" alt="" class="logo-mark" aria-hidden="true" />
        <span class="logo-text">glyph</span>
      </a>
    </header>

    <!-- ── HERO ── -->
    <section class="hero">
      <div class="dock" aria-hidden="true">
        <img src="/dock.png" alt="" class="dock-img" />
      </div>

      <h1>
        <span class="h1-line" data-reveal>Your space to think with</span>
        <span class="h1-line" data-reveal style="--delay: 80ms"><strong>notes,</strong></span>
        <span class="h1-line" data-reveal style="--delay: 160ms"><strong class="italic">links</strong> or anything else.</span>
      </h1>

      <div class="hero-actions" data-reveal style="--delay: 240ms">
        <a href="#" class="btn-primary">
          <svg class="btn-apple" width="14" height="17" viewBox="0 0 14 17" fill="none" aria-hidden="true"><path d="M13.2 13.14c-.31.72-.68 1.38-1.12 1.99-.59.83-1.08 1.41-1.45 1.73-.58.53-1.2.8-1.86.81-.48 0-1.05-.13-1.73-.41-.68-.27-1.3-.41-1.87-.41-.59 0-1.23.14-1.91.41C2.58 17.53 2.02 17.67 1.57 17.68c-.63.02-1.26-.26-1.9-.84C-.73 16.49-1.25 15.88-1.87 15.01c-.67-.93-1.22-2.01-1.64-3.24C-3.94 10.44-4.16 9.15-4.16 7.91c0-1.41.3-2.63.92-3.65a5.38 5.38 0 0 1 1.92-1.94A5.16 5.16 0 0 1 1.27 1.5c.5 0 1.16.16 1.98.47.82.31 1.34.47 1.57.47.17 0 .75-.19 1.72-.56.92-.35 1.69-.49 2.32-.43 1.72.14 3.01.82 3.86 2.05-1.54.93-2.3 2.24-2.28 3.92.02 1.31.49 2.4 1.4 3.27.42.4.88.7 1.4.92-.11.33-.23.64-.36.94zM9.54-3.32c0 1.03-.37 1.99-1.12 2.87-.9 1.05-1.99 1.66-3.17 1.57a3.19 3.19 0 0 1-.02-.39c0-.99.43-2.04 1.19-2.9.38-.44.86-.8 1.45-1.09.59-.28 1.14-.44 1.67-.47v.41z" transform="translate(4.16 3.32)" fill="currentColor"/></svg>
          Get Glyph for Mac
        </a>
      </div>
      <p class="hero-sub" data-reveal style="--delay: 300ms">
        free &amp; open source. no subscriptions.
      </p>
    </section>

    <!-- ── PRODUCT SHOWCASE ── -->
    <section class="showcase" data-reveal style="--delay: 350ms">
      <img
        class="showcase-img"
        src="/main_image.png"
        alt="Glyph workspace showing the markdown editor, file tree, and AI chat panel"
        loading="eager"
      />
    </section>

    <!-- ── NOT YOUR AVERAGE ── -->
    <section class="features-intro" data-reveal>
      <div class="section-marker" aria-hidden="true"></div>
      <h2><strong>Not</strong> your average notes app</h2>
      <p class="section-sub">
        Scattered docs and clunky apps are over. Local-first markdown is where it's at.
      </p>
    </section>

    <!-- ── FEATURES GRID ── -->
    <section class="features-grid" data-reveal>
      {features.map((f) => (
        <div class="feature-cell">
          <div class="feature-head">
            <h3>{f.title}</h3>
            <span class="feature-num">{f.num}</span>
          </div>
          <p class="feature-desc">{f.desc}</p>
        </div>
      ))}
    </section>

    <!-- ── SHOWCASE 2 ── -->
    <section class="canvas-showcase" data-reveal>
      <h2>The editor is your <em>canvas</em></h2>
      <p class="section-sub">
        Wikilinks, slash commands, and AI — all in one place. Build a writing workflow that fits the way you already think.
      </p>
      <div class="canvas-demo">
        <img
          src="/main-image.png"
          alt="Glyph editor with markdown, AI panel, and file tree"
          class="canvas-demo-img"
          loading="lazy"
        />
      </div>
    </section>

    <!-- ── BEAUTIFULLY DESIGNED ── -->
    <section class="design-section" data-reveal>
      <h2>Obsessively <em>crafted</em></h2>
      <p class="section-sub">
        A native macOS app built by people who sweat the details. Every pixel, every shortcut, every transition.
      </p>
      <div class="design-grid">
        {details.map((d) => (
          <div class="design-card">
            <h3>{d.title}</h3>
            <p>{d.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <p class="delights" data-reveal>...and a million other small delights.</p>

    <!-- ── LOCAL FIRST ── -->
    <section class="local-section" data-reveal>
      <h2>Yours, <em>completely</em></h2>
      <p class="section-sub">
        Your notes never leave your machine. No account, no cloud, no telemetry. Open a folder and start writing.
      </p>
      <div class="local-visual" aria-hidden="true">
        <div class="file-tree-mock">
          <div class="ft-header">
            <span class="ft-dot"></span>
            <span class="ft-dot"></span>
            <span class="ft-dot"></span>
            <span class="ft-title">~/vault</span>
          </div>
          <div class="ft-body">
            <div class="ft-row folder">Projects</div>
            <div class="ft-row file">meeting-notes.md</div>
            <div class="ft-row file">architecture.md</div>
            <div class="ft-row folder">Daily</div>
            <div class="ft-row file">2026-03-02.md</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section class="faq-section" data-reveal>
      <h2>Frequent questions</h2>
      <div class="faq-list">
        {faqs.map((f, i) => (
          <details class="faq-item">
            <summary class="faq-summary">
              <span class="faq-num">{String(i + 1).padStart(2, "0")}</span>
              <span class="faq-question">{f.q}</span>
              <span class="faq-chevron" aria-hidden="true">+</span>
            </summary>
            <div class="faq-answer">
              <p>{f.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="cta-section" data-reveal>
      <h2>Get Glyph on Mac</h2>
      <div class="cta-actions">
        <a href="#" class="btn-primary btn-large">
          <svg class="btn-apple" width="14" height="17" viewBox="0 0 14 17" fill="none" aria-hidden="true"><path d="M13.2 13.14c-.31.72-.68 1.38-1.12 1.99-.59.83-1.08 1.41-1.45 1.73-.58.53-1.2.8-1.86.81-.48 0-1.05-.13-1.73-.41-.68-.27-1.3-.41-1.87-.41-.59 0-1.23.14-1.91.41C2.58 17.53 2.02 17.67 1.57 17.68c-.63.02-1.26-.26-1.9-.84C-.73 16.49-1.25 15.88-1.87 15.01c-.67-.93-1.22-2.01-1.64-3.24C-3.94 10.44-4.16 9.15-4.16 7.91c0-1.41.3-2.63.92-3.65a5.38 5.38 0 0 1 1.92-1.94A5.16 5.16 0 0 1 1.27 1.5c.5 0 1.16.16 1.98.47.82.31 1.34.47 1.57.47.17 0 .75-.19 1.72-.56.92-.35 1.69-.49 2.32-.43 1.72.14 3.01.82 3.86 2.05-1.54.93-2.3 2.24-2.28 3.92.02 1.31.49 2.4 1.4 3.27.42.4.88.7 1.4.92-.11.33-.23.64-.36.94zM9.54-3.32c0 1.03-.37 1.99-1.12 2.87-.9 1.05-1.99 1.66-3.17 1.57a3.19 3.19 0 0 1-.02-.39c0-.99.43-2.04 1.19-2.9.38-.44.86-.8 1.45-1.09.59-.28 1.14-.44 1.67-.47v.41z" transform="translate(4.16 3.32)" fill="currentColor"/></svg>
          Download for Mac
        </a>
      </div>
    </section>

    <!-- ── FOOTER ── -->
    <footer class="footer">
      <div class="footer-inner">
        <a href="#" class="logo" aria-label="Glyph home">
          <img src="/glyph-logo.png" alt="" class="logo-mark" aria-hidden="true" />
          <span class="logo-text">glyph</span>
        </a>
        <div class="footer-links">
          <a href="#">GitHub</a>
          <a href="#">Discord</a>
          <a href="#">Changelog</a>
        </div>
      </div>
      <p class="footer-copy">© 2026 Glyph. All rights reserved.</p>
    </footer>
  </main>
</Layout>

<style>
  /* ── Layout ── */
  .page {
    position: relative;
    overflow-x: hidden;
  }

  .header,
  .hero,
  .features-intro,
  .features-grid,
  .canvas-showcase,
  .design-section,
  .local-section,
  .faq-section,
  .cta-section,
  .footer {
    width: min(740px, 90vw);
    margin-inline: auto;
  }

  /* ── Decorative squares ── */
  .deco {
    position: absolute;
    width: 12px;
    height: 12px;
    pointer-events: none;
    z-index: 1;
  }

  .deco-1 { top: 180px; right: calc(50% + 370px); background: var(--purple); }
  .deco-2 { top: 220px; left: calc(50% + 360px); background: var(--accent); }
  .deco-3 { top: 300px; right: calc(50% + 350px); background: var(--magenta); }
  .deco-4 { top: 620px; left: calc(50% + 370px); background: var(--cyan); }
  .deco-5 { top: 520px; right: calc(50% + 340px); background: var(--magenta); }

  /* ── Header ── */
  .header {
    display: flex;
    justify-content: center;
    padding: 2rem 0 1.5rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo-mark {
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 4px;
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ── Hero ── */
  .hero {
    text-align: center;
    padding: 2rem 0 3rem;
  }

  .dock {
    display: flex;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .dock-img {
    max-width: 420px;
    width: 100%;
    height: auto;
  }

  h1 {
    font-family: var(--font-sans);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 0 2rem;
  }

  h1 strong {
    font-weight: 900;
    letter-spacing: -0.05em;
  }

  h1 .italic {
    font-style: italic;
    font-weight: 900;
    letter-spacing: -0.05em;
  }

  .h1-line {
    display: block;
  }

  .hero-actions {
    margin-bottom: 1rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.6rem;
    background: var(--accent);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
    box-shadow: 0 2px 12px rgba(255, 215, 0, 0.3);
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(255, 215, 0, 0.4);
  }

  .btn-primary:active { transform: translateY(1px); }

  .btn-large {
    padding: 0.85rem 2rem;
    font-size: 0.85rem;
  }

  .btn-apple {
    flex-shrink: 0;
  }

  .hero-sub {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--subtle);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* ── Showcase ── */
  .showcase {
    width: 100%;
    padding: 0 0 6rem;
  }

  .showcase-img {
    width: 100%;
    display: block;
  }

  /* ── Section typography ── */
  h2 {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0;
  }

  h2 strong {
    font-weight: 900;
    letter-spacing: -0.05em;
  }

  h2 em {
    font-style: italic;
    font-weight: 900;
    letter-spacing: -0.05em;
  }

  .section-marker {
    width: 10px;
    height: 10px;
    background: var(--accent);
    margin: 0 auto 1rem;
  }

  .section-sub {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.7;
    margin-top: 0.75rem;
    max-width: 500px;
  }

  /* ── Features intro ── */
  .features-intro {
    text-align: center;
    padding: 6rem 0 3rem;
  }

  .features-intro .section-sub {
    margin-inline: auto;
  }

  /* ── Features grid ── */
  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--line);
    margin-bottom: 6rem;
  }

  .feature-cell {
    padding: 2rem;
    border-bottom: 1px solid var(--line);
    transition: background 0.25s ease;
  }

  .feature-cell:hover {
    background: var(--surface);
  }

  .feature-cell:nth-child(odd) {
    border-right: 1px solid var(--line);
  }

  .feature-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .feature-cell h3 {
    font-family: var(--font-sans);
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0;
  }

  .feature-num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--subtle);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .feature-desc {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--muted);
    margin: 0;
  }

  /* ── Canvas showcase ── */
  .canvas-showcase {
    text-align: center;
    padding: 0 0 6rem;
  }

  .canvas-showcase .section-sub {
    margin-inline: auto;
  }

  .canvas-demo {
    margin-top: 2.5rem;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow:
      0 27px 16px rgba(0, 0, 0, 0.04),
      0 12px 12px rgba(0, 0, 0, 0.06),
      0 3px 7px rgba(0, 0, 0, 0.08);
  }

  .canvas-demo-img {
    width: 100%;
    display: block;
  }

  /* ── Design section ── */
  .design-section {
    text-align: center;
    padding: 6rem 0;
    border-top: 1px solid var(--line);
  }

  .design-section .section-sub {
    margin-inline: auto;
  }

  .design-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-top: 3rem;
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    background: var(--line);
  }

  .design-card {
    background: var(--bg);
    padding: 1.5rem;
    text-align: left;
    transition: background 0.25s ease;
  }

  .design-card:hover {
    background: var(--surface);
  }

  .design-card h3 {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .design-card p {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Delights ── */
  .delights {
    width: min(740px, 90vw);
    margin-inline: auto;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-style: italic;
    font-weight: 500;
    color: var(--subtle);
    padding: 2rem 0 0;
  }

  /* ── Local section ── */
  .local-section {
    text-align: center;
    padding: 6rem 0;
    border-top: 1px solid var(--line);
  }

  .local-section .section-sub {
    margin-inline: auto;
  }

  .local-visual {
    max-width: 340px;
    margin: 2.5rem auto 0;
  }

  .file-tree-mock {
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
    background: var(--bg);
  }

  .ft-header {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
    background: var(--surface);
  }

  .ft-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--line);
  }

  .ft-title {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 500;
    margin-left: 6px;
  }

  .ft-body { padding: 8px 0; }

  .ft-row {
    display: flex;
    align-items: center;
    padding: 0.35rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--muted);
  }

  .ft-row.folder { font-weight: 600; color: var(--ink); }
  .ft-row.folder::before {
    content: '▸';
    margin-right: 0.5rem;
    color: var(--accent);
    font-size: 0.78rem;
  }

  .ft-row.file { padding-left: 2.6rem; }
  .ft-row.file::before {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    background: var(--line);
    border-radius: 1px;
    margin-right: 0.5rem;
    flex-shrink: 0;
  }

  /* ── FAQ ── */
  .faq-section {
    padding: 6rem 0;
    border-top: 1px solid var(--line);
  }

  .faq-section h2 {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-top: 1px solid var(--line);
  }

  .faq-item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .faq-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::marker { display: none; content: ''; }

  .faq-num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--subtle);
    flex-shrink: 0;
    width: 2rem;
  }

  .faq-question {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--ink);
    flex: 1;
    transition: color 0.2s ease;
  }

  .faq-chevron {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    color: var(--subtle);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(45deg);
  }

  .faq-summary:hover .faq-question {
    color: var(--muted);
  }

  .faq-answer {
    padding: 0 0 1.2rem 3rem;
  }

  .faq-answer p {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }

  /* ── CTA ── */
  .cta-section {
    text-align: center;
    padding: 6rem 0;
    border-top: 1px solid var(--line);
  }

  .cta-actions {
    margin-top: 2rem;
  }

  /* ── Footer ── */
  .footer {
    padding: 6rem 0 2rem;
    border-top: 1px solid var(--line);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--line);
  }

  .footer-links {
    display: flex;
    gap: 2rem;
  }

  .footer-links a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--subtle);
    transition: color 0.18s ease;
  }

  .footer-links a:hover { color: var(--ink); }

  .footer-copy {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--subtle);
    letter-spacing: 0.02em;
  }

  /* ── Reveal animations ── */
  :global([data-reveal]) {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease var(--delay, 0ms), transform 0.6s ease var(--delay, 0ms);
  }

  :global([data-reveal].revealed) {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    :global([data-reveal]) {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 680px) {
    .deco { display: none; }

    h1 { font-size: clamp(2.2rem, 9vw, 3.2rem); }

    .dock-img { max-width: 300px; }



    .features-grid { grid-template-columns: 1fr; }
    .feature-cell:nth-child(odd) { border-right: none; }

    .design-grid { grid-template-columns: 1fr; }

    .footer-inner {
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-start;
    }

    .footer-links { flex-wrap: wrap; gap: 1.2rem; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
</script>
