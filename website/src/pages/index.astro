---
import Layout from '../layouts/Layout.astro';

const svgAttrs = 'width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"';

const pillars = [
  {
    num: '01',
    verb: 'Write.',
    subtitle: 'A markdown editor that stays out of your way',
    text: 'Start typing, or hit / for commands. Headings, lists, code blocks, and embeds render as you type. Select text for a floating toolbar. Your files are plain .md — open them in anything.',
  },
  {
    num: '02',
    verb: 'Connect.',
    subtitle: 'See how your ideas relate',
    text: 'Link notes with [[double brackets]] and see what links back. Drag notes, images, and web links onto a spatial canvas. Your thinking becomes something you can see and rearrange.',
  },
  {
    num: '03',
    verb: 'Ask.',
    subtitle: 'An AI that reads your notes',
    text: 'Chat with an AI that has context on your vault. Ask it to summarize a meeting, compare two documents, or draft something new. Bring your own key — OpenAI, Anthropic, or a local model.',
  },
];

const features = [
  {
    icon: `<svg ${svgAttrs}><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>`,
    title: 'Daily notes',
    text: 'A fresh page every morning, auto-titled and ready to go.',
  },
  {
    icon: `<svg ${svgAttrs}><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 12l2 2 4-4"/></svg>`,
    title: 'Tasks',
    text: 'Write checkboxes in any note. Glyph gathers them into Inbox, Today, and Upcoming.',
  },
  {
    icon: `<svg ${svgAttrs}><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>`,
    title: 'Instant search',
    text: '⌘P to find anything. Filter by tags, folders, or full-text content.',
  },
  {
    icon: `<svg ${svgAttrs}><path d="M4 9h16M4 15h16M10 3l-2 18M16 3l-2 18"/></svg>`,
    title: 'Tags',
    text: 'Organize with #tags and browse your vault by topic.',
  },
  {
    icon: `<svg ${svgAttrs}><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 8h20M8 4v4"/></svg>`,
    title: 'Tabs',
    text: 'Keep multiple notes open. Switch between them like browser tabs.',
  },
  {
    icon: `<svg ${svgAttrs}><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 10h.01M10 10h.01M14 10h.01M18 10h.01M8 14h8"/></svg>`,
    title: 'Keyboard-first',
    text: 'Navigate, create, and search — without lifting your hands from the keyboard.',
  },
  {
    icon: `<svg ${svgAttrs}><rect x="1" y="7" width="22" height="10" rx="5"/><circle cx="16" cy="12" r="3"/></svg>`,
    title: 'Make it yours',
    text: 'Choose your accent color, pick a font, adjust the layout to fit how you think.',
  },
  {
    icon: `<svg ${svgAttrs}><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>`,
    title: 'Pinned folders',
    text: 'Keep your most-used folders one click away in the sidebar.',
  },
];

const stats = [
  { value: '< 1s', label: 'to launch' },
  { value: '~80 MB', label: 'of memory' },
  { value: '0 bytes', label: 'uploaded' },
  { value: '.md', label: 'plain files' },
];

const useCases = [
  {
    marker: 'R',
    title: 'Researchers',
    text: 'Link papers to reading notes, tag concepts across projects, and ask the AI to summarize or compare sources — all from one local vault.',
  },
  {
    marker: 'E',
    title: 'Engineers',
    text: 'Keep architecture decisions, runbooks, and code snippets in markdown. Use the canvas to map systems and the AI to answer questions about your docs.',
  },
  {
    marker: 'W',
    title: 'Writers',
    text: 'Outline chapters on the canvas, write drafts in the editor, and tag scenes by character or theme. The AI helps brainstorm without breaking your flow.',
  },
];
---

<Layout>
  <main class="page">
    <!-- ── NAV ── -->
    <header class="topbar shell">
      <a href="#" class="brand" aria-label="Glyph home">
        <img class="brand-mark" src="/glyph-logo.png" alt="" aria-hidden="true" />
        <span class="brand-text">Glyph</span>
      </a>
      <nav class="nav" aria-label="Main navigation">
        <a href="#features">Features</a>
        <a href="#use-cases">Use Cases</a>
      </nav>
      <a class="nav-cta" href="#">
        Download
        <span class="nav-cta-arrow" aria-hidden="true">↓</span>
      </a>
    </header>

    <!-- ── HERO ── -->
    <section class="hero shell">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="badge">
            <span class="badge-dot" aria-hidden="true"></span>
            Now available for macOS
          </p>
          <h1>
            <span class="h1-line">Your notebook,</span>
            <span class="h1-line">but it thinks</span>
            <span class="h1-line">with you.</span>
          </h1>
          <p class="lede">
            Glyph is a desktop app for writing, connecting, and
            exploring your notes — with an AI that actually reads
            what you've written.
          </p>
          <div class="actions">
            <a href="#" class="btn btn-primary">
              Download for macOS
              <span class="btn-arrow" aria-hidden="true">→</span>
            </a>
            <a href="#" class="btn btn-ghost">View on GitHub</a>
          </div>
        </div>

        <div class="hero-media-wrap">
          <div class="hero-glow" aria-hidden="true"></div>
          <img
            class="hero-media"
            src="/main-image.png"
            alt="Glyph workspace showing the markdown editor, file tree, and AI chat panel"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- ── PILLARS ── -->
    <section id="features" class="pillars shell">
      <div class="section-head" data-reveal>
        <p class="eyebrow">How it works</p>
        <h2>Three ways to work with your&nbsp;notes.</h2>
      </div>

      <div class="pillar-grid">
        {pillars.map((p, i) => (
          <article class="pillar-card" data-reveal style={`--delay: ${i * 80}ms`}>
            <span class="pillar-num" aria-hidden="true">{p.num}</span>
            <h3 class="pillar-verb">{p.verb}</h3>
            <p class="pillar-subtitle">{p.subtitle}</p>
            <p class="pillar-text">{p.text}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ── FEATURES ── -->
    <section class="extras shell">
      <div class="section-head" data-reveal>
        <p class="eyebrow">And everything else</p>
        <h2>The details that make it feel like&nbsp;home.</h2>
      </div>

      <div class="extras-grid">
        {features.map((f, i) => (
          <article class="extra-card" data-reveal style={`--delay: ${i * 50}ms`}>
            <div class="extra-icon" set:html={f.icon} />
            <h3>{f.title}</h3>
            <p>{f.text}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ── PRIVACY ── -->
    <section class="privacy shell">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Local-first</p>
        <h2>Yours, completely.</h2>
      </div>
      <p class="privacy-text" data-reveal>
        Glyph reads files from your disk and never phones home.
        No account. No subscription. No cloud sync.
        Just open a folder and start writing.
      </p>
      <div class="stats-grid" data-reveal>
        {stats.map((s) => (
          <div class="stat">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ── USE CASES ── -->
    <section id="use-cases" class="use-cases shell">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Who it's for</p>
        <h2>People who think for a&nbsp;living.</h2>
      </div>

      <div class="uc-grid">
        {useCases.map((uc, i) => (
          <article class="uc-card" data-reveal style={`--delay: ${i * 80}ms`}>
            <div class="uc-marker" aria-hidden="true">{uc.marker}</div>
            <h3>{uc.title}</h3>
            <p>{uc.text}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="cta-section shell" data-reveal>
      <div class="cta-box">
        <p class="cta-eyebrow">Get started</p>
        <h2>Open a folder.<br />Start&nbsp;writing.</h2>
        <p class="cta-sub">Free to download. Works offline. Your files stay on your machine.</p>
        <div class="actions cta-actions">
          <a href="#" class="btn btn-cta-primary">
            Download for macOS
            <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
          <a href="#" class="btn btn-cta-ghost">View on GitHub</a>
        </div>
      </div>
    </section>

    <!-- ── FOOTER ── -->
    <footer class="footer shell">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="#" class="brand" aria-label="Glyph home">
            <img class="brand-mark" src="/glyph-logo.png" alt="" aria-hidden="true" />
            <span class="brand-text">Glyph</span>
          </a>
          <p class="footer-tagline">A local-first markdown editor with AI.</p>
        </div>
        <div class="footer-links">
          <div class="footer-col">
            <h4>Product</h4>
            <a href="#features">Features</a>
            <a href="#">Changelog</a>
            <a href="#">Pricing</a>
          </div>
          <div class="footer-col">
            <h4>Community</h4>
            <a href="#">Documentation</a>
            <a href="#">GitHub</a>
            <a href="#">Discord</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Glyph. All rights reserved.</p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  /* ── Page ── */
  .page {
    padding: 1.5rem 0 0;
    position: relative;
  }

  .shell {
    width: min(1200px, 92vw);
    margin-inline: auto;
  }

  /* ── Section Heads ── */
  .section-head {
    margin-bottom: 3rem;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    max-width: 560px;
    margin: 0;
    color: var(--ink);
  }

  /* ── Topbar ── */
  .topbar {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0.75rem 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .brand-mark {
    width: 1.85rem;
    height: 1.85rem;
    object-fit: cover;
    border-radius: 0.22rem;
    display: block;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.8rem;
    margin-left: auto;
  }

  .nav a {
    font-size: 0.88rem;
    color: var(--muted);
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav a:hover {
    color: var(--ink);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    padding: 0.45rem 1.1rem;
    border: 1.5px solid var(--accent);
    border-radius: 999px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .nav-cta:hover {
    background: var(--accent);
    color: #fff;
  }

  .nav-cta-arrow {
    font-size: 0.75rem;
  }

  /* ── Hero ── */
  .hero {
    padding: 5rem 0 6rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 4rem;
    align-items: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.38rem 1rem;
    background: var(--accent-soft);
    border-radius: 999px;
    font-size: 0.8rem;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 1.8rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5.5vw, 4.2rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    margin: 0 0 1.5rem;
    color: var(--ink);
  }

  .h1-line {
    display: block;
    opacity: 0;
    animation: fadeUp 0.55s ease both;
  }

  .h1-line:nth-child(1) { animation-delay: 0.1s; }
  .h1-line:nth-child(2) { animation-delay: 0.2s; }
  .h1-line:nth-child(3) { animation-delay: 0.3s; }

  .lede {
    font-size: 1.12rem;
    line-height: 1.65;
    color: var(--muted);
    max-width: 440px;
    margin: 0 0 2rem;
  }

  /* ── Buttons ── */
  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.72rem 1.5rem;
    border-radius: var(--radius);
    font-size: 0.92rem;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    border: none;
    transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn:active {
    transform: translateY(1px);
  }

  .btn-arrow {
    transition: transform 0.2s ease;
  }

  .btn:hover .btn-arrow {
    transform: translateX(3px);
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 4px 16px -4px rgba(74, 103, 65, 0.35);
  }

  .btn-primary:hover {
    background: #3d5736;
    box-shadow: 0 8px 24px -4px rgba(74, 103, 65, 0.4);
  }

  .btn-ghost {
    background: transparent;
    border: 1.5px solid var(--line);
    color: var(--ink);
  }

  .btn-ghost:hover {
    border-color: var(--muted);
    background: var(--surface);
  }

  /* ── Hero Media ── */
  .hero-media-wrap {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(
      ellipse at 40% 50%,
      rgba(74, 103, 65, 0.12) 0%,
      transparent 60%
    ),
    radial-gradient(
      ellipse at 70% 30%,
      rgba(184, 149, 106, 0.1) 0%,
      transparent 50%
    );
    z-index: 0;
    pointer-events: none;
  }

  .hero-media {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.85rem;
    border: 1px solid var(--line);
    box-shadow:
      0 24px 80px -16px rgba(21, 19, 14, 0.18),
      0 8px 24px -8px rgba(21, 19, 14, 0.08);
    position: relative;
    z-index: 1;
  }

  /* ── Pillars ── */
  .pillars {
    padding: 5rem 0;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .pillar-card {
    padding: 2rem 2rem 2.2rem;
    border-left: 3px solid var(--accent);
    background: var(--surface);
    border-radius: 0 var(--radius) var(--radius) 0;
    transition: box-shadow 0.25s ease;
  }

  .pillar-card:hover {
    box-shadow: 0 8px 32px -8px rgba(21, 19, 14, 0.08);
  }

  .pillar-num {
    display: block;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }

  .pillar-verb {
    font-family: var(--font-display);
    font-size: 1.65rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.35rem;
    color: var(--ink);
  }

  .pillar-subtitle {
    font-size: 0.95rem;
    color: var(--accent);
    font-weight: 500;
    margin: 0 0 1rem;
  }

  .pillar-text {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
  }

  /* ── Extras ── */
  .extras {
    padding: 4rem 0 5rem;
  }

  .extras-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .extra-card {
    padding: 1.5rem;
    background: var(--surface);
    border-radius: var(--radius);
    border: 1px solid var(--line);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }

  .extra-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(21, 19, 14, 0.06);
  }

  .extra-icon {
    width: 2.4rem;
    height: 2.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.45rem;
    background: var(--accent-soft);
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .extra-icon :global(svg) {
    width: 1.2rem;
    height: 1.2rem;
  }

  .extra-card h3 {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .extra-card p {
    font-size: 0.84rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }

  /* ── Privacy ── */
  .privacy {
    padding: 5rem 0;
  }

  .privacy-text {
    font-size: 1.12rem;
    line-height: 1.7;
    color: var(--muted);
    max-width: 520px;
    margin: -1rem 0 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    margin-top: 2.5rem;
  }

  .stat {
    background: var(--surface);
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.02em;
  }

  .stat-label {
    display: block;
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 0.3rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  /* ── Use Cases ── */
  .use-cases {
    padding: 4rem 0 5rem;
  }

  .uc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .uc-card {
    padding: 2rem;
    background: var(--surface);
    border-radius: var(--radius);
    border: 1px solid var(--line);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .uc-card:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
  }

  .uc-marker {
    width: 2.2rem;
    height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), #C9A87A);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    margin-bottom: 1.2rem;
  }

  .uc-card h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .uc-card p {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  /* ── CTA ── */
  .cta-section {
    padding: 2rem 0 0;
  }

  .cta-box {
    text-align: center;
    padding: 5rem 2rem;
    border-radius: 1.2rem;
    background: var(--ink);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .cta-box::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(74, 103, 65, 0.2) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(184, 149, 106, 0.12) 0%, transparent 50%);
    pointer-events: none;
  }

  .cta-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.35);
    font-weight: 700;
    margin: 0 0 1.2rem;
    position: relative;
  }

  .cta-box h2 {
    font-family: var(--font-display);
    color: #fff;
    font-size: clamp(1.9rem, 3.5vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0;
    position: relative;
  }

  .cta-sub {
    margin: 1rem 0 0;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1rem;
    position: relative;
  }

  .cta-actions {
    justify-content: center;
    margin-top: 2.2rem;
    position: relative;
  }

  .btn-cta-primary {
    background: #fff;
    color: var(--ink);
    box-shadow: 0 8px 28px -8px rgba(255, 255, 255, 0.15);
  }

  .btn-cta-primary:hover {
    background: #F0EDE6;
