---
interface Props {
	title?: string;
}

import logoG from "../../assets/logo_g.PNG";

const { title = "Glyph — A space to think" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={logoG.src} />
		<link rel="apple-touch-icon" href={logoG.src} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta
			name="description"
			content="Glyph is a local-first desktop notebook for writing, connecting, and exploring ideas. Markdown, wikilinks, AI. Built with Tauri and Rust."
		/>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>

		<link rel="preload" as="image" href="/light.webp" fetchpriority="high" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg: #fafafa;
		--ink: #111;
		--muted: #666;
		--faint: #999;
		--border: #e0e0e0;
		--dot: #d4d4d4;
		--serif: 'Instrument Serif', 'Times New Roman', serif;
		--mono: 'Space Grotesk', 'Helvetica Neue', sans-serif;
	}

	* { box-sizing: border-box; margin: 0; padding: 0; }
	html { scroll-behavior: smooth; }

	body {
		font-family: var(--mono);
		font-size: 13px;
		color: var(--ink);
		background-color: var(--bg);
		background-image: radial-gradient(circle, var(--dot) 1px, transparent 1px);
		background-size: 22px 22px;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	a { color: inherit; text-decoration: none; }
	img { display: block; max-width: 100%; }
</style>
