<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/glyph-logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Glyph — A local-first markdown editor with AI</title>
    <meta
      name="description"
      content="Glyph is a desktop markdown editor that works on your local files. Link notes with wikilinks, think on a visual canvas, and talk to an AI agent that reads your vault. Built with Tauri and Rust."
    />

    <!-- Font fallback (prevents FOIT) -->
    <style>
      @font-face {
        font-family: 'Bricolage Grotesque';
        font-display: swap;
        src: local('Bricolage Grotesque');
      }
      @font-face {
        font-family: 'DM Sans';
        font-display: swap;
        src: local('DM Sans');
      }
    </style>

    <!-- Non-blocking Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      />
    </noscript>

    <!-- Preload LCP image -->
    <link rel="preload" as="image" href="/main-image.png" fetchpriority="high" />
  </head>
  <body>
    <slot />
    <div class="grain" aria-hidden="true"></div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #EDEAE3;
    --surface: #F8F7F3;
    --ink: #15130E;
    --muted: #7A766D;
    --line: #DAD6CE;
    --accent: #4A6741;
    --accent-soft: #E8EDE6;
    --gold: #B8956A;
    --radius: 0.65rem;
    --font-display: 'Bricolage Grotesque', system-ui, sans-serif;
    --font-body: 'DM Sans', system-ui, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
    font-family: var(--font-body);
    font-optical-sizing: auto;
    color: var(--ink);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  /* Grain overlay */
  .grain {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.14;
    mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 180px;
  }
</style>
